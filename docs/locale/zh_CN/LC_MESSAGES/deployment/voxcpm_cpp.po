#: ../../deployment/voxcpm_cpp.rst:5 94d7538b43bc44008b7b11a920e6e765
msgid ""
"VoxCPM.cpp is a standalone C++ inference engine for VoxCPM based on ggml, "
"with GGUF model support."
msgstr "VoxCPM.cpp 是基于 ggml 的 VoxCPM 独立 C++ 推理引擎，支持 GGUF 模型。"

#: ../../deployment/voxcpm_cpp.rst:7 ea9ab895f499460c8fce70cf7ec73021
msgid "Repo: `bluryar/VoxCPM.cpp <https://github.com/bluryar/VoxCPM.cpp>`_"
msgstr "仓库：`bluryar/VoxCPM.cpp <https://github.com/bluryar/VoxCPM.cpp>`_"

#: ../../deployment/voxcpm_cpp.rst:8 5ebde85f1ef440f698ea4f0a0f683208
msgid ""
"GGUF Weights: `bluryar/VoxCPM-GGUF <https://huggingface.co/bluryar/VoxCPM-"
"GGUF>`_"
msgstr "GGUF 权重：`bluryar/VoxCPM-GGUF <https://huggingface.co/bluryar/VoxCPM-GGUF>`_"

#: ../../deployment/voxcpm_cpp.rst:9 940f9b4470ab44fc9c2d3efce7c5a37c
msgid "Upstream: `OpenBMB/VoxCPM <https://github.com/OpenBMB/VoxCPM>`_"
