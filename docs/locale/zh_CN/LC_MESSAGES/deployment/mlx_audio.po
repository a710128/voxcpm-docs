msgid "✅ Supported"
msgstr "✅ 支持"

#: ../../deployment/mlx_audio.rst:18 2d88bc3a79c34bdfa31068bcddd2d10d
msgid "VoxCPM 1.5"
msgstr "VoxCPM 1.5"

#: ../../deployment/mlx_audio.rst:20 9d1ee48ac0174772a59ec3dbbb75fc25
msgid "VoxCPM 2"
msgstr "VoxCPM 2"

#: ../../deployment/mlx_audio.rst:21 0b2d6832463f4072abfa4a60ad6f52b0
msgid "⚠️ This page focuses on the current VoxCPM 1.x path on MLX-Audio"
msgstr "⚠️ 本页主要介绍 MLX-Audio 上当前的 VoxCPM 1.x 路径"

#: ../../deployment/mlx_audio.rst:24 a705c901aae04bf996fd58d79a491b35
msgid "Prerequisites"
msgstr "准备工作"

#: ../../deployment/mlx_audio.rst:26 77a7e0fa960a4080a27f807d9bd85a77
