msgid "✅ Supported (``voxcpm2`` architecture auto-detected from ``config.json``)"
msgstr "✅ 支持（从 ``config.json`` 自动检测 ``voxcpm2`` 架构）"

#: ../../deployment/nanovllm_voxcpm.rst:27 c6eb9afe5d3248b2876b9bd30de8736d
msgid "Features"
msgstr "Features"

#: ../../deployment/nanovllm_voxcpm.rst:29 19657a9bcb21499d9441a29dd993ce3f
msgid "High throughput on CUDA devices (RTX 4090, H100, A100, etc.)"
msgstr "在 CUDA 设备上高吞吐（RTX 4090、H100、A100 等）"

#: ../../deployment/nanovllm_voxcpm.rst:30 e41a645d9fe5486f8783a3b5c09f8577
msgid "Concurrent requests via an internal scheduler"
msgstr "通过内部调度器并发处理请求"

#: ../../deployment/nanovllm_voxcpm.rst:31 9d6cf45b465b433ca2d6c54122342347
msgid "Streaming inference (yield waveform chunks)"
msgstr "流式推理（按块产出波形）"

#: ../../deployment/nanovllm_voxcpm.rst:32 c61d635fd4914432811f0f1afe02c507
msgid "Optional HTTP demo server (FastAPI)"
msgstr "可选的 HTTP 演示服务（FastAPI）"

#: ../../deployment/nanovllm_voxcpm.rst:33 8be6ad7655dc4dc4af8f453bd99de32d
msgid "Multi-GPU request-level parallelism via a server pool (one process per GPU)"
msgstr "通过服务池实现多 GPU 请求级并行（每块 GPU 一个进程）"

