msgstr "主入口为 ``nanovllm_voxcpm.VoxCPM.from_pretrained(...)``。"

#: ../../deployment/nanovllm_voxcpm.rst:84 eb136f9f32ab42208045a4f3880dc69c
msgid "Generate (async streaming)"
msgstr "Generate (async streaming)"

#: ../../deployment/nanovllm_voxcpm.rst:86 eb47c815aae5432681402b3d0eca0b5a
