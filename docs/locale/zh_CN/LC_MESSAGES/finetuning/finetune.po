msgid "``true``"
msgstr "``true``"

#: ../../finetuning/finetune.rst:221 92f8614e317a46048c1fb69efaab8fa9
msgid "``enable_dit``"
msgstr "``enable_dit``"

#: ../../finetuning/finetune.rst:222 a64097e29cdc4980896d608603253f71
msgid "Apply LoRA to the diffusion transformer"
msgstr "对扩散 Transformer（DiT）应用 LoRA"

#: ../../finetuning/finetune.rst:223 c1f79ce04f624bde85ba4a1f97d81011
msgid "``true`` (essential for voice quality)"
msgstr "``true`` （对音质至关重要）"

