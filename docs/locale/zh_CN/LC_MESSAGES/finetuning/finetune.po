#: ../../finetuning/finetune.rst:226 7a6bb15f41e84112b8206ea9371e0b17
msgid "``false`` for most cases"
msgstr "多数场景用 ``false``"

#: ../../finetuning/finetune.rst:227 7d7f1d7b9d64416593fbb9c1397da9e9
msgid "``r``"
msgstr "``r``"

#: ../../finetuning/finetune.rst:228 485a0c5f1d844146a92c0160c12c92c7
msgid "LoRA rank — higher means more capacity"
msgstr "LoRA 秩（rank）— 越大容量越高"

#: ../../finetuning/finetune.rst:229 675f2f251b8e47aab16b0c1bcb66d2d2
msgid "32 for speaker cloning, 64 for style/language adaptation"
msgstr "克隆说话人用 32；风格/语言适配用 64"

#: ../../finetuning/finetune.rst:230 2a2a7c25550a4b1e8ce20fe148ba6a2b
