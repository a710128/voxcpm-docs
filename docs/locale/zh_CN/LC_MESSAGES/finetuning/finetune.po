msgid ""
"**Format:** WAV is recommended. Other formats supported by torchaudio also "
"work."
msgstr "**格式：** 建议使用 WAV；torchaudio 支持的其它格式也可用。"

#: ../../finetuning/finetune.rst:100 80e0b5cc4e7e4d8b8f6385a4f215060a
msgid ""
"**Sample rate:** The dataloader automatically resamples to the target "
"model's rate, so you do not need to pre-resample. The native rates are:"
msgstr "**采样率：** 数据加载器会自动重采样到目标模型的采样率，一般无需预先重采样。各版本原生采样率为："

#: ../../finetuning/finetune.rst:102 46fbea52e2f545a0ad20fdc42e7e3522
msgid "VoxCPM 1.0: 16kHz"
msgstr "VoxCPM 1.0：16 kHz"

#: ../../finetuning/finetune.rst:103 1db2c79c70554965a731d3f010fad172
msgid "VoxCPM 1.5: 44.1kHz"
msgstr "VoxCPM 1.5：44.1 kHz"

#: ../../finetuning/finetune.rst:104 005a001e7a2343d3a931ef1ce79d2c09
