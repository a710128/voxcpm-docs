msgstr "缩放因子（``scaling = alpha / r``）"

#: ../../finetuning/finetune.rst:232 33e5167b69a042ed8c8fc178c8634490
msgid "Usually ``r`` or ``2*r``. Adjust to control LoRA influence strength."
msgstr "通常取 ``r`` 或 ``2*r``，按需调节 LoRA 影响强度。"

#: ../../finetuning/finetune.rst:233 c7f06cdf04204ca79f4b6aa6cb1cb6a9
msgid "``dropout``"
msgstr "``dropout``"

#: ../../finetuning/finetune.rst:234 e6f420745515474eb8ec74e53ca5d078
msgid "Dropout on LoRA layers"
msgstr "LoRA 层上的 Dropout"

#: ../../finetuning/finetune.rst:235 432590491efe4871a4c808315580876f
msgid "``0.0`` unless overfitting"
msgstr "除非过拟合，否则 ``0.0``"

#: ../../finetuning/finetune.rst:237 ../../finetuning/finetune.rst:410
#: aab3776fb7fc4a2c8d73b24621e2de8a f445022a45794479aed4ef50bb52de0d
