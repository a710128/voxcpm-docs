msgid "``cuda`` / ``cpu`` / ``mps`` / ``directml`` / ``hip`` (varies by hardware)"
msgstr "``cuda`` / ``cpu`` / ``mps`` / ``directml`` / ``hip`` （视硬件而定）"

#: ../../integrations/comfyui_voxcpm.rst:112 b1a83f53884942e98526fb0b308a86b3
