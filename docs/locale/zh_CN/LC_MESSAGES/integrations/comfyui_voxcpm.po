msgstr "``normalize_text``"

#: ../../integrations/comfyui_voxcpm.rst:113 ba6871f9fcf043f3b8eecca4410f1a71
msgid "Enable external text normalization (disable for phoneme input)"
msgstr "启用外部文本规范化（音素输入时请关闭）"

#: ../../integrations/comfyui_voxcpm.rst:114 c514469c377b4f09a5abbe3fcd4cd18b
msgid "``seed``"
msgstr "``seed``"

#: ../../integrations/comfyui_voxcpm.rst:115 c9a4d856062649048380cc4721b35173
msgid "Random seed for reproducibility (default: -1 for random)"
msgstr "随机种子以保证可复现（默认 -1 表示随机）"

#: ../../integrations/comfyui_voxcpm.rst:116 1c1ce76a245f4396bcf69ef1771c471b
msgid "``lora_name``"
msgstr "``lora_name``"

#: ../../integrations/comfyui_voxcpm.rst:117 2f6233db84464675a8e446c0ec867165
msgid "Select a LoRA adapter from ``models/loras``"
msgstr "从 ``models/loras`` 选择 LoRA 适配器"

#: ../../integrations/comfyui_voxcpm.rst:118 0706d7b84d2240ccbb15661336711531
msgid "``min_tokens`` / ``max_tokens``"
msgstr "``min_tokens`` / ``max_tokens``"

#: ../../integrations/comfyui_voxcpm.rst:119 866f84448d164362af6d9411c78f5747
msgid "Token length range for generation"
msgstr "生成时的 token 长度范围"

#: ../../integrations/comfyui_voxcpm.rst:120 4f4ba6119e7a4562b25e1891724ecf93
msgid "``force_offload``"
msgstr "``force_offload``"

#: ../../integrations/comfyui_voxcpm.rst:121 3b66cc001b534275abc80255e8768fab
msgid "Offload model from GPU after inference to save VRAM"
msgstr "推理后将模型从 GPU 卸载以节省显存"

#: ../../integrations/comfyui_voxcpm.rst:122 728a7a2cf3974168884d048f232574f3
msgid "``retry_max_attempts``"
msgstr "``retry_max_attempts``"

#: ../../integrations/comfyui_voxcpm.rst:123 36714002abe54dd185972fc9fc4b1930
msgid "Maximum retries for bad generation outputs"
msgstr "劣质输出的最大重试次数"

#: ../../integrations/comfyui_voxcpm.rst:124 15d62f58c3f3407b948cde90b36bd74b
msgid "``retry_threshold``"
msgstr "``retry_threshold``"

#: ../../integrations/comfyui_voxcpm.rst:125 a545319c98d44a828f2dc72a5f376dfb
msgid "Threshold for bad-case detection"
msgstr "坏例检测阈值"

#: ../../integrations/comfyui_voxcpm.rst:128 565e490f91514093bb142aade2fd4c0a
msgid "Troubleshooting"
msgstr "问题排查"

#: ../../integrations/comfyui_voxcpm.rst:131 9da6cf44f0554275890d73434b554d14
msgid "Out of memory"
msgstr "显存不足"

#: ../../integrations/comfyui_voxcpm.rst:133 423c3a4b35624a1f9c3b5262bb89f180
msgid "Set ``force_offload`` to ``True`` to release GPU memory after each generation"
msgstr "将 ``force_offload`` 设为 ``True``，每次生成后释放 GPU 显存"

#: ../../integrations/comfyui_voxcpm.rst:134 969b15b8ee1c4f3ebc3dfac944579455
msgid "Switch to ``cpu`` device (slower but uses system RAM)"
msgstr "改用 ``cpu`` 设备（更慢但使用系统内存）"

#: ../../integrations/comfyui_voxcpm.rst:135 28dcff7654b64cbdbe54a46444c0a87c
msgid "Use VoxCPM-0.5B instead of 1.5 for lower memory usage"
msgstr "若显存紧张可改用 VoxCPM-0.5B 而非 1.5"

